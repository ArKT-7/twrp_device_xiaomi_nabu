#!/sbin/bash
lin=/dev/block/platform/soc/1d84000.ufshc/sda32
esp=/dev/block/platform/soc/1d84000.ufshc/sda31

stockpart(){
sgdisk --clear --load-backup=/system/bin/stock_gpt /dev/block/sda
}

formatlinuxesp(){
mkfs.fat -F32 -s1 $esp -n ESPNABU
mke2fs -t ext4 -F $lin
}

formatdata(){
make_f2fs -f -g android /dev/block/sda33
mke2fs -t ext4 -F /dev/block/sda19
}

formatdatarestore(){
make_f2fs -f -g android /dev/block/sda31
mke2fs -t ext4 -F /dev/block/sda19
}

restore(){
stockpart
parted -s /dev/block/sda resizepart 31 100%
sync
formatdatarestore
}

umountm() {
	local part
	local args
	local real_part
	part="${1:-}"
	args=()
	if [ -n "$part" ]; then
		if [ $# -gt 0 ]; then
			shift
			args=("$@")
		fi
		if [ -L "$part" ]; then
			real_part=$(readlink -f "$part")
		else
			real_part="$part"
		fi
		if grep -q "$real_part" /proc/mounts; then
			umount "$part" "${args[@]}"
		fi
	fi
}

attach_chroot() {
        local lin=/dev/block/by-name/linux
        local esp=/dev/block/by-name/esp
        [ -b "$lin" ] || { echo -e "\nError! Linux partition not found, Please create the partition first\n"; exit 1; }
        [ -b "$esp" ] || { echo -e "\nError! ESP partition not found, Please create the partition first\n"; exit 1; }
        mkdir /mnt/linux/root -p
        mount "$lin" /mnt/linux/root || { echo -e "\nFailed to mount $lin\n"; exit 1; }
        if [ -b "$esp" ]; then
                mkdir -p /mnt/linux/root/boot/efi
                mount "$esp" /mnt/linux/root/boot/efi || { echo -e "\nFailed to mount $esp\n"; exit 1; }
        fi
        mount -t proc proc /mnt/linux/root/proc || echo "Failed to mount proc"
        mount -t sysfs sysfs /mnt/linux/root/sys || echo "Failed to mount sys"
        mount -o bind /dev /mnt/linux/root/dev || echo "Failed to bind /dev"
        mount -o bind /dev/pts /mnt/linux/root/dev/pts || echo "Failed to bind /dev/pts"
}

detach_chroot() {
	umountm /mnt/linux/root/dev/pts
	umountm /mnt/linux/root/dev
	umountm /mnt/linux/root/sys
	umountm /mnt/linux/root/proc
	umountm /mnt/linux/root/boot/efi
	umountm /mnt/linux/root
}

[ -e /config/usb_gadget/g1/configs/b.1/mass_storage.0 ] && echo "msc is enabled! aborting..." && echo "reboot and run the script again." && exit 1

if getprop sys.usb.config | grep -q "mtp"; then
    echo " "
    echo "run the script again!"
    sleep 1
    setprop sys.usb.config adb
    rm /config/usb_gadget/g1/configs/b.1/f*
    exit
fi

max=$(( $(blockdev --getsize64 /dev/block/sda) / 1000000 ))

for i in sdcard data; do umount -lf /$i 2>/dev/null; done
dmsetup remove -f userdata 2>/dev/null
for i in esp win linux firmware mnt userdata metadata misc vendor; do umount -lf /dev/block/platform/soc/1d84000.ufshc/by-name/$i 2> /dev/null; done

detach_chroot
