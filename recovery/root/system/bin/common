#!/sbin/bash
win=/dev/block/sda32
esp=/dev/block/sda31
removeparts(){
    for i in $(seq 31 40); do
        parted -s /dev/block/sda rm $i 2>/dev/null
    done
}

formatwinesp(){
mkfs.fat -F32 -s1 $esp -n ESPNABU
mkfs.ntfs -f $win -L WINNABU
}

formatdata(){
make_f2fs -f -g android /dev/block/sda31
mke2fs -t ext4 -F /dev/block/sda19
}

formatwindata(){
make_f2fs -f -g android /dev/block/sda33
mke2fs -t ext4 -F /dev/block/sda19
}

restore(){
removeparts
parted -s /dev/block/sda mkpart userdata ext4 10872MB  100%
sync
formatdata
}

fixgpt(){
  for d in /dev/block/sd[a-f]; do
    [ -b "$d" ] && printf 'x\nj\n\nk\n\nw\nY\n' | gdisk "$d"
  done
}

[ -e /config/usb_gadget/g1/configs/b.1/mass_storage.0 ] && echo "msc is enabled! aborting..." && echo "reboot and run the script again." && exit 1

if getprop sys.usb.config | grep -q "mtp"; then
    echo " "
    echo "run the script again!"
    sleep 1
    setprop sys.usb.config adb
    rm /config/usb_gadget/g1/configs/b.1/f*
    exit
fi

for i in sdcard data; do umount -lf /$i 2>/dev/null; done
dmsetup remove -f userdata 2>/dev/null
for i in esp win linux firmware mnt userdata metadata misc vendor; do umount -lf /dev/block/by-name/$i 2> /dev/null; done

restoregptstock() {
  restore_one() {
    gpt=$1 idx=$2 backup="/sbin/gpt$idx"
    [ -f "$backup" ] || { echo "No backup $backup"; return 1; }
    for p in ${gpt}*; do umount "$p" 2>/dev/null; swapoff "$p" 2>/dev/null; done
    (mount | grep -q "$gpt" || grep -q "$gpt" /proc/swaps) && { echo "$gpt busy"; return 1; }
    sgdisk --pretend --clear --load-backup="$backup" "$gpt" || { echo "Dry-run fail $gpt"; return 1; }
    sgdisk --clear --load-backup="$backup" "$gpt" || return 1
    if [ "$gpt" = "/dev/block/sda" ]; then
      parted -s "$gpt" resizepart 31 100%
      sync; formatdata; parted "$gpt" p free
    fi
    echo "$gpt restored"
  }
  if [ $# -eq 0 ]; then
    i=0
    for g in /dev/block/sd[a-f]; do restore_one "$g" $i; i=$((i+1)); done
  else
    case $1 in
      [0-5]) g=/dev/block/sd$(printf \\$(printf '%o' $((97+$1)))); restore_one "$g" $1 ;;
      *) echo "Usage: restoregptstock [0-5]"; return 1 ;;
    esac
  fi
}

[ "$ignorekrjy" = true ] || {
  bad=0
  for i in 1 2 3 4; do [ -e /dev/block/by-name/bk0$i ] || bad=1; done
  for d in /dev/block/sda3[5-9] /dev/block/sda[4-9][0-9]; do [ -e "$d" ] && bad=1; done
  [ "$bad" = 1 ] && {
    echo "Partition table modified! Restoring stock will WIPE ALL DATA."
    echo -n "Continue? (y/n): "; read yn
    case $yn in [Yy]*) restoregptstock 0;; *) echo "Aborting."; exit 1;; esac
  }
}
