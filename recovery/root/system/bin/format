#!/sbin/bash
linpart=/dev/block/platform/soc/1d84000.ufshc/by-name/linux
esppart=/dev/block/platform/soc/1d84000.ufshc/by-name/esp
[ -e "$linpart" -a -e "$esppart" ] || { echo "nothing to format huh. check your partitions"; exit 1; }
target=$1
#force unmount and suppress errors
force_umount() {
    umount -lf "$1" 2>/dev/null || true
}
#format ESP only
if [ "$target" = "esp" ]; then
    echo "Formatting ESP partition..."
    force_umount "$esppart"
    mkfs.fat -F32 -s1 "$esppart" -n ESPNABU
    echo "ESP format done!"
    exit 0
fi
#format LIN only
if [ "$target" = "lin" ]; then
    echo "Formatting LINUX partition..."
    force_umount "$linpart"
    mkfs.ext4 -F -L linux "$linpart"
    echo "LINUX format done!"
    exit 0
fi
#normally format both
echo "Formatting ESP and LINUX partitions..."
force_umount "$esppart"
force_umount "$linpart"
mkfs.fat -F32 -s1 "$esppart" -n ESPNABU
mkfs.ext4 -F -L linux "$linpart"
echo "Both partitions formatted successfully!"
