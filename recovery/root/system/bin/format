#!/sbin/bash
winpart=/dev/block/platform/soc/1d84000.ufshc/by-name/win
esppart=/dev/block/platform/soc/1d84000.ufshc/by-name/esp
[ -e $winpart -a -e $esppart ] || { echo "nothing to format huh. check your partitions"; exit 1; }
umount $winpart
umount $esppart
mkfs.fat -F32 -s1 $esppart -n ESPNABU
mkfs.ntfs -f $winpart -L WINNABU
echo "done!"
