#!/sbin/bash
winpart=/dev/block/platform/soc/1d84000.ufshc/by-name/win
esppart=/dev/block/platform/soc/1d84000.ufshc/by-name/esp
[ -e "$winpart" -a -e "$esppart" ] || { echo "nothing to format huh. check your partitions"; exit 1; }
target=$1
#format ESP only
if [ "$target" = "esp" ]; then
    echo "Formatting ESP partition..."
    umount "$esppart"
    mkfs.fat -F32 -s1 "$esppart" -n ESPNABU
    echo "ESP format done!"
    exit 0
fi
#format WIN only
if [ "$target" = "win" ]; then
    echo "Formatting WIN partition..."
    umount "$winpart"
    mkfs.ntfs -f "$winpart" -L WINNABU
    echo "WIN format done!"
    exit 0
fi
#normally format both
echo "Formatting ESP and WIN partitions..."
umount "$esppart"
umount "$winpart"
mkfs.fat -F32 -s1 "$esppart" -n ESPNABU
mkfs.ntfs -f "$winpart" -L WINNABU
echo "Both partitions formatted successfully!"
