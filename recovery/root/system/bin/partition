#!/sbin/sh
. common
max=$(parted -s /dev/block/sda unit MB p -m | grep '^/dev/block/sda:' | cut -d: -f2 | tr -cd '0-9')
[ -z "$max" ] && { echo "Failed to get disk size"; exit 1; }
RESERVED_START=11222 RESERVED_END=7000
winmax=$(( (max - RESERVED_START - RESERVED_END)/1000 ))

[ -n "$1" ] && s="$1" || { echo "Enter Windows size GB (25-$winmax)"; read s; [ -z "$s" ] && exit 1; }
s=$(echo "$s" | tr -cd '0-9.')

case $s in *.*) i=${s%.*}; f=${s#*.}; pow=1; for j in $(seq 1 ${#f}); do pow=$((pow*10)); done
  mb=$((i*1000 + f*1000/pow)) ;; *) mb=$((s*1000)) ;; esac

[ $mb -lt 25000 ] || [ $mb -gt $((winmax*1000)) ] && { echo "un.. type correctly"; exit 1; }

winend=$(( mb + RES_START ))
echo "Windows: $(( (winend-RES_START)/1000 )) GB, Android: $(( (max-winend)/1000 )) GB"
echo -n "Does this sound good (y/n)? "; read yn
case "$yn" in [Yy]*) ;; *) echo "Rethink things carefully and, eventually, you'll come to a conclusion."; exit 1;; esac

disk=/dev/block/sda
stockpart
sgdisk --resize-table 64 $d
parted -s $disk rm 31 \
	mkpart esp fat32 10872MB 11222MB \
    mkpart win ntfs 11222MB ${winend}MB \
    mkpart userdata ext4 ${winend}MB 100% \
    set 31 esp on
sync; formatwindata; formatwinesp; fixgpt
parted $d p free
echo done
