#!/sbin/bash
. common

RESERVED_START=11222
RESERVED_END=7000

usable_mb=$((max - RESERVED_START - RESERVED_END))
winmax=$((usable_mb / 1000))
input="${1-}"
size=$(echo "$input" | tr -d '[:space:]' | tr '[:upper:]' '[:lower:]' | sed 's/gb$//;s/[^0-9.]//g')
if [[ -z "$input" ]]; then
    winend=$(((max + RESERVED_START) / 2))
else
    if ! [[ "$size" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
        echo "Invalid input. Please enter a number (e.g., 60GB)" >&2
        exit 1
    fi
    size_int=$(echo "$size" | cut -d'.' -f1)
    if (( size_int < 30 || size_int > winmax )); then
        echo "Invalid size! Min: 30GB, Max: ${winmax}GB" >&2
        exit 1
    fi
    winend=$(echo "$size * 1000" | bc)
    winend=$(printf "%.0f" "$winend")
    winend=$(( (winend + 1023) / 1024 * 1024 ))
    winend=$((winend + RESERVED_START))
fi
windows_gb=$(echo "scale=2; ($winend - $RESERVED_START) / 1000" | bc)
userdata_gb=$(echo "scale=2; ($max - $winend) / 1000" | bc)
echo ""
echo "Windows Partition: $windows_gb GB"
echo "Android Partition: $userdata_gb GB"
while true; do
  echo ""
  echo -n "Does this look good? (y/n): "
  read yn
  case "$yn" in
    [Yy]* ) break ;;
    [Nn]* ) echo "Operation cancelled"; exit 1 ;;
    * ) echo "Please enter (yes/y/Y or no/n/N)." ;;
  esac
done
echo ""
echo "Proceeding with Windows partitioning..."
echo ""
disk=/dev/block/sda
removeparts
sgdisk --resize-table 64 "$disk"
parted -s "$disk" \
  mkpart esp fat32 10872MB 11222MB \
  mkpart win ntfs 11222MB "${winend}MB" \
  mkpart userdata ext4 "${winend}MB" 100% \
  set 31 esp on

sync
formatwindata
formatwinesp
fixgpt
sync
parted "$disk" p free
echo "done!"