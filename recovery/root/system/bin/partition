#!/sbin/bash
if [[ -n $1 ]]; then
	. common
	linmax=$(echo "($max - 11222 - 8000)/1000" | bc)
	echo "min size is 30, max size is less then $linmax"

	if ! [[ -z $2 && $1 =~ ^[0-9]{1,3}(\.[0-9])?$ && $(echo "30 < $1 && $1 < $linmax" | bc) == 1 ]]; then
		echo "invalid argument!"
		exit 1
	fi

	echo "$(echo "scale=2; $1*1000/1024" | bc)GiB of space will be given to the main linux parition"
	linend=$(echo "$1*1000 + 11222" | bc)
	echo "userdata will get $(echo "scale=2;($max-$linend)/1024" | bc)GiB of space"
	echo -n "does that sound good (y/n)? "
	read -r yn
	[[ $yn =~ ^[Yy].*$ ]] || {
		echo "rethink things carefully and, eventually, you'll come to a conclusion."
		exit 1
	}
else
	echo "Usage: parition [linux partition size in GiB]"
	exit 1
fi

removeparts
sgdisk --resize-table 64 /dev/block/sda
parted -s /dev/block/sda \
	mkpart esp fat32 10872MB 11222MB \
	mkpart linux ext4 11222MB "$linend" \
	mkpart userdata ext4 "$linend" 100% \
	set 31 esp on
sync
formatlinuxesp
formatdata
echo "done!"
