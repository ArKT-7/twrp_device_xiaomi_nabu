#!/sbin/bash

winpart=/dev/block/by-name/win
defaultpath=/sdcard/winbackup

printf "\n==== Windows Backup ====\n"
printf "Default backup path: $defaultpath\n"
printf "Enter custom path or press Enter to use default:\n> "
read -r p
backuppath="${p:-$defaultpath}"

mkdir -p "$backuppath" || { echo "Failed to create $backuppath"; exit 1; }
touch "$backuppath/.test" && rm "$backuppath/.test" || { echo "Path not writable"; exit 1; }

[ -e "$winpart" ] || { echo "Win partition missing"; exit 1; }

umount -f "$winpart" 2>/dev/null
mkdir -p /win && mount.ntfs "$winpart" /win || { echo "Mount failed"; exit 1; }

requsize=$(df -k /win | awk 'NR==2 {printf "%d", $3*0.7}') || { echo "Failed to get Win usage"; exit 1; }
avaisize=$(df -k "$backuppath" | awk 'NR==2 {print $4}') || { echo "Failed to get available space"; exit 1; }

echo "Required Size : $(awk "BEGIN {printf \"%.2f\", $requsize/1e6}") GB"
echo "Avalable size : $(awk "BEGIN {printf \"%.2f\", $avaisize/1e6}") GB"

[ "$avaisize" -gt "$requsize" ] || { echo "Not enough free space"; exit 1; }

echo "Backing up Win..."
wimlib capture "$winpart" "$backuppath/winbackup.wim" || exit 1
echo "Backup complete to $backuppath"
