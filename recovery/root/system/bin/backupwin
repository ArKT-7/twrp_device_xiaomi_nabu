#!/bin/sh

winpart=/dev/block/platform/soc/1d84000.ufshc/by-name/win
defaultpath=/sdcard/winbackup

printf "\n==== Windows Backup ====\n"
printf "Default backup path: /sdcard/winbackup\n"
printf "Enter custom path or press Enter to use default:\n> "
read -r p
backuppath="${p:-/sdcard/winbackup}"

mkdir -p "$backuppath" || { echo "Failed to create $backuppath"; exit 1; }
touch "$backuppath/.test" && rm "$backuppath/.test" || { echo "Path not writable"; exit 1; }

[ -e "$winpart" ] || { echo "Win partition missing"; exit 1; }

umount -f "$winpart" 2>/dev/null
mkdir -p /win && mount.ntfs "$winpart" /win || { echo "Mount failed"; exit 1; }

reqb=$(df -k /win | awk 'NR==2 {print $3}') || { echo "Failed to get Win usage"; exit 1; }
availb=$(df -k "$backuppath" | awk 'NR==2 {print $4}') || { echo "Failed to get available space"; exit 1; }

reqgb=$(awk "BEGIN {printf \"%.2f\", $reqb/1e6}")
availgb=$(awk "BEGIN {printf \"%.2f\", $availb/1e6}")

echo " Required Size  : $reqgb GB"
echo " Available Size : $availgb GB"

[ "$availb" -lt "$reqb" ] && {
  echo "Not enough space: Need $reqgb GB, available $availgb GB"
  exit 1
}

echo "Backing up Win..."
wimlib capture "$winpart" "$backuppath/winbackup.wim" || exit 1
echo "Backup complete to $backuppath"
