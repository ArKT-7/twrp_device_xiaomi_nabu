#!/sbin/sh
winpart=/dev/block/platform/soc/1d84000.ufshc/by-name/win
printf "\n=== Windows Backup Restore ===\n"
printf "Default backup path: /sdcard/winbackup\n"
printf "Enter custom path or press Enter to use default:\n> "
read -r p
backuppath="${p:-/sdcard/winbackup}"
winimage=$(find "$backuppath" -maxdepth 1 -type f 2>/dev/null | grep -iE '\.(esd|wim)$' | head -n1) \
    || { echo "Failed to search for image in $backuppath"; exit 1; }
[ -f "$winimage" ] || { echo "No backup image found in $backuppath"; exit 1; }
required=$(wimlib-imagex info "$winimage" | grep "Total bytes" | awk -F: '{gsub(/ /,"",$2);print $2}') \
    || { echo "Failed to read image size from $winimage"; exit 1; }
[ "$(blockdev --getsize64 "$winpart")" -gt "$required" ] || { echo "WIN partition is too small"; exit 1; }
umount "$winpart" 2>/dev/null
mkfs.ntfs -f -Q -L WINNABU "$winpart" || { echo "Failed to format $winpart as NTFS"; exit 1; }
wimlib-imagex apply "$winimage" 1 "$winpart" || { echo "Failed to apply image to $winpart"; exit 1; }
echo "Restoration complete"
