+int GUIAction::rotationbyarkt(std::string arg __unused)
+{
+	LOGINFO("TWRP ROTATION BY ARKT...\n");
+	// === Check if MSC is enabled ===
+	if (access("/config/usb_gadget/g1/configs/b.1/mass_storage.0", F_OK) == 0) {
+		LOGINFO("Mass storage is already enabled! Reboot and run the script again.\n");
+	    LOGINFO("Mass storage detected. Aborting theme rotation.\n");
+		// Show your custom GUI page
+		gui_changeOverlay("msc_enabled");
+		return 1;
+	}
+	
+
+    // === Backup current layout XMLs and images ===
+    LOGINFO("Backing up current twres...\n");
+    system("mkdir -p /twres/twres-arkt/backup");
+    system("mv /twres/ui.xml /twres/twres-arkt/backup/ui.xml");
+    system("mv /twres/splash.xml /twres/twres-arkt/backup/splash.xml");
+    system("mv /twres/images /twres/twres-arkt/backup/images");
+    system("[ -f /twres/portrait.xml ] && mv /twres/portrait.xml /twres/twres-arkt/backup/portrait.xml");
+    system("[ -f /twres/landscape.xml ] && mv /twres/landscape.xml /twres/twres-arkt/backup/landscape.xml");
+
+    // === Copy in new layout from twres-arkt ===
+    LOGINFO("Swapping in new layout...\n");
+    system("mv /twres/twres-arkt/ui.xml /twres/");
+    system("mv /twres/twres-arkt/splash.xml /twres/");
+    system("mv /twres/twres-arkt/images /twres/");
+    system("[ -f /twres/twres-arkt/portrait.xml ] && mv /twres/twres-arkt/portrait.xml /twres/");
+    system("[ -f /twres/twres-arkt/landscape.xml ] && mv /twres/twres-arkt/landscape.xml /twres/");
+
+    // === Restore previous layout to arkt backup ===
+    LOGINFO("Moving previous layout into /twres-arkt...\n");
+    system("mv /twres/twres-arkt/backup/ui.xml /twres/twres-arkt/ui.xml");
+    system("mv /twres/twres-arkt/backup/splash.xml /twres/twres-arkt/splash.xml");
+    system("mv /twres/twres-arkt/backup/images /twres/twres-arkt/images");
+    system("[ -f /twres/twres-arkt/backup/portrait.xml ] && mv /twres/twres-arkt/backup/portrait.xml /twres/twres-arkt/portrait.xml");
+    system("[ -f /twres/twres-arkt/backup/landscape.xml ] && mv /twres/twres-arkt/backup/landscape.xml /twres/twres-arkt/landscape.xml");
+
+    // === libminuitwrp.so swap ===
+    system("[ -f /system/lib64/libminuitwrp.so ] && mv /system/lib64/libminuitwrp.so /system/lib64/libminuitwrp-arkt-1.so");
+    system("[ -f /system/lib64/libminuitwrp-arkt.so ] && mv /system/lib64/libminuitwrp-arkt.so /system/lib64/libminuitwrp.so");
+    system("[ -f /system/lib64/libminuitwrp-arkt-1.so ] && mv /system/lib64/libminuitwrp-arkt-1.so /system/lib64/libminuitwrp-arkt.so");
+
+	// === ramdisk-files-arkt.so swap ===
+    system("[ -f /ramdisk-files.txt ] && mv /ramdisk-files.txt /ramdisk-files-arkt-1.txt");
+    system("[ -f /ramdisk-files-arkt.txt ] && mv /ramdisk-files-arkt.txt /ramdisk-files.txt");
+    system("[ -f /ramdisk-files-arkt-1.txt ] && mv /ramdisk-files-arkt-1.txt /ramdisk-files-arkt.txt");
+
+    // === Fix mounts and start MTP again ===
+       // === Fix mounts and restart MTP ===
+    LOGINFO("Unmounting and reinitializing...\n");
+    DataManager::Flush();
+    system("umount -l /dev/block/platform/soc/1d84000.ufshc/by-name/esp");
+    system("umount -l /dev/block/platform/soc/1d84000.ufshc/by-name/win");
+    LOGINFO("Unmounting DONE...\n");
+   // === Fork + signal recovery to reload ===
+    pid_t pid = fork();
+    if (pid == 0) {
+        ::sleep(1);  
+		LOGINFO("KILLING TWRP FOR ROTATION...\n");
+        execlp("killall", "killall", "-SIGUSR1", "recovery", (char*)nullptr);
+        _exit(0); // child exit
+    }
+
+	// android::base::SetProperty("sys.usb.config", "adb");
+	LOGINFO("KILLING DONE...\n");
+    // Main function ends here
+	LOGINFO("TWRP ROTATION DONE BY ARKT ...\n");
+    return 0;
+}
