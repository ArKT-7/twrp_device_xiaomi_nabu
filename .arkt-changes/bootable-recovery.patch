+    Exec_Cmd("[ -f /system/lib64/libminuitwrp-arkt-1.so ] && mv /system/lib64/libminuitwrp-arkt-1.so /system/lib64/libminuitwrp-arkt.so");
+
+    // Swap ramdisk files for rotation
+    Exec_Cmd("[ -f /ramdisk-files.txt ] && mv /ramdisk-files.txt /ramdisk-files-arkt-1.txt");
+    Exec_Cmd("[ -f /ramdisk-files-arkt.txt ] && mv /ramdisk-files-arkt.txt /ramdisk-files.txt");
+    Exec_Cmd("[ -f /ramdisk-files-arkt-1.txt ] && mv /ramdisk-files-arkt-1.txt /ramdisk-files-arkt.txt");
+
+    LOGINFO("Unmounting and reinitializing...\n");
+    sync();
+    DataManager::Flush();
+
+    // Unmount partitions forcefully
+    Exec_Cmd("umount -lf /dev/block/platform/soc/1d84000.ufshc/by-name/win >/dev/null 2>&1 || true");
+    Exec_Cmd("umount -lf /dev/block/platform/soc/1d84000.ufshc/by-name/esp >/dev/null 2>&1 || true");
+
+    Exec_Cmd("sync");
+
+    // Fork a child process to kill twrp with SIGUSR1 to rotate UI
+    pid_t pid = fork();
+    if (pid == 0) {
+        ::sleep(1);
+        LOGINFO("KILLING TWRP FOR ROTATION...\n");
+        execlp("killall", "killall", "-SIGUSR1", "recovery", (char*)nullptr);
+        _exit(0); // child exit
+    }
+
+    LOGINFO("TWRP ROTATION DONE BY ARKT ...\n");
+}
+
+
+void TWFunc::CommonByArKT() 
+{
+    // Check if MTP mode is active, then reset USB to ADB mode
+    int mtpActive = system("getprop sys.usb.config | grep -q 'mtp'");
+    if (mtpActive == 0) {
+        gui_print("\nMTP mode detected. Resetting USB to ADB...\n");
+        PartitionManager.Disable_MTP();
+        android::base::SetProperty("sys.usb.config", "none");
+        android::base::SetProperty("sys.usb.config", "adb");
+        Exec_Cmd("rm -f /config/usb_gadget/g1/configs/b.1/f* || true");
+        ::sleep(2);
+    }
+
+    gui_print("\nUnmounting all related partitions...\n");
+
+    // Unmount common mount points and partitions
+    Exec_Cmd("for i in sdcard data; do umount -lf /$i 2>/dev/null || true; done");
+    Exec_Cmd("dmsetup remove -f userdata 2>/dev/null || true");
+    Exec_Cmd("for i in esp win firmware mnt userdata metadata misc vendor; do umount -lf /dev/block/platform/soc/1d84000.ufshc/by-name/$i > /dev/null 2>&1 || true; done");
+}
+
+
+void TWFunc::partedprintByArKT() 
+{
+    gui_print("\nFetching partition list...\n\n");
+
+    // Run parted asynchronously to get and print partition info
+    std::thread([] {
+        std::this_thread::sleep_for(std::chrono::milliseconds(100));
+        std::string parted_output;
+        int code = Exec_Cmd("parted /dev/block/sda p free", parted_output, true);
+
+        if (code != 0 || parted_output.empty()) {
+            gui_print("Failed to get partition list.\n");
+            gui_print("%s\n", parted_output.c_str());
+            return;
+        }
+
+        std::istringstream stream(parted_output);
+        std::string line;
+
+        while (std::getline(stream, line)) {
+            gui_print("%s\n", line.c_str());
+            std::this_thread::sleep_for(std::chrono::milliseconds(5));
+        }
+
+        gui_print("\nDone!\n");
+    }).detach();
+
+    gui_print("\n");
+}
+
+
+void TWFunc::FormatWinByArKT() 
+{
+    gui_print("\nFormatting WIN and ESP partitions...\n");
+
+    // Format WIN and ESP partitions asynchronously
+    std::thread([] {
+        std::this_thread::sleep_for(std::chrono::milliseconds(300));
+
+        std::string win_part = "/dev/block/platform/soc/1d84000.ufshc/by-name/win";
+        std::string esp_part = "/dev/block/platform/soc/1d84000.ufshc/by-name/esp";
+
+        if (!TWFunc::Path_Exists(win_part) || !TWFunc::Path_Exists(esp_part)) {
+            gui_print("Nothing to format. Check your partitions if it has Windows & ESP Partitions.\n");
+            return;
+        }
+
+        Exec_Cmd("sync");
+        Exec_Cmd("umount -lf " + win_part + " >/dev/null 2>&1 || true");
+        Exec_Cmd("umount -lf " + esp_part + " >/dev/null 2>&1 || true");
+
+        std::this_thread::sleep_for(std::chrono::milliseconds(500));
+
+        // Clear first sector to erase old data
+        Exec_Cmd("dd if=/dev/zero of=" + win_part + " bs=512 count=1 >/dev/null 2>&1 || true");
+        Exec_Cmd("dd if=/dev/zero of=" + esp_part + " bs=512 count=1 >/dev/null 2>&1 || true");
+        Exec_Cmd("sync");
+
+        // Attempt quick fix on NTFS partition
+        Exec_Cmd("ntfsfix " + win_part + " >/dev/null 2>&1 || true");
+
+        // Format ESP partition as FAT32
+        std::string esp_out;
+        int esp_code = Exec_Cmd("mkfs.fat -F32 -s1 " + esp_part + " -n ESPNABU", esp_out, true);
+        gui_print("\n%s", esp_out.c_str());
+
+        std::this_thread::sleep_for(std::chrono::milliseconds(500));
+
+        // Format WIN partition as NTFS
+        std::string win_out;
+        int win_code = Exec_Cmd("mkfs.ntfs -f " + win_part + " -L WINNABU", win_out, true);
+        gui_print("%s\n", win_out.c_str());
+
+        std::this_thread::sleep_for(std::chrono::milliseconds(500));
+        Exec_Cmd("sync");
+
+        if (esp_code == 0 && win_code == 0)
+            gui_print("Both WIN and ESP formatted successfully!\n");
+        else
+            gui_print("Formatting failed for one or both partitions. Check above.\n");
+
+        sync();
+    }).detach();
+}
