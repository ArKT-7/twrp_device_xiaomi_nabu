+// Show rotation warning UI, perform rotation logic
+int GUIAction::rotationbyarkt(std::string arg __unused)
+{
+	gui_changeOverlay("rotation_warn");
+	// Run restore steps asynchronously to avoid blocking UI
+    std::thread([] {
+		sync();
+        std::this_thread::sleep_for(std::chrono::milliseconds(300));
+    	TWFunc::RotationByArkt();
+    }).detach();
+
+    sync();
+    return 0;
+}
+
+// Reboot device with different options based on arg
+int GUIAction::rebootbyarkt(std::string arg)
+{
+    if (arg == "r") {
+        TWFunc::Exec_Cmd("reboot >/dev/null 2>&1 || true");
+    } else if (arg == "rtbl") {
+        TWFunc::Exec_Cmd("reboot bootloader >/dev/null 2>&1 || true");
+    } else if (arg == "rtr") {
+        TWFunc::Exec_Cmd("reboot recovery >/dev/null 2>&1 || true");
+    } else if (arg == "off") {
+        TWFunc::Exec_Cmd("reboot poweroff >/dev/null 2>&1 || true");
+    }
+    return 0;
+}
