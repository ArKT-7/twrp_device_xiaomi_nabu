+        if (TWFunc::Path_Exists(orsFile)) {
+            LOGINFO("Script file found: '%s'\n", orsFile.c_str());
+            TWFunc::copy_file(orsFile, SCRIPT_FILE_TMP, 0755);
+            unlink(orsFile.c_str());
+            return 1;
+        }
+    }
+    return 0;
 }
 
