+void TWFunc::PartitionSizesByArKT() {
+	std::string win_raw, esp_raw, userdata_raw;
+	std::string win_val = "NA", win_unit = "MB", win_display = "NA";
+	std::string esp_val = "NA", esp_unit = "MB", esp_display = "NA";
+	std::string userdata_val = "NA", userdata_unit = "MB", userdata_display = "NA";
+
+	auto clean_float_str = [](float value) -> std::string {
+		std::ostringstream oss;
+		oss.precision(2);
+		oss << std::fixed << value;
+		std::string out = oss.str();
+		while (out.back() == '0') out.pop_back();
+		if (out.back() == '.') out.pop_back();
+		return out;
+	};
+
+	// WIN Partition
+	if (Exec_Cmd("blockdev --getsize64 /dev/block/by-name/win | awk '{printf \"%.0fMB\\n\", $1 / 1000 / 1000}'", win_raw, true) == 0) {
+		if (win_raw.find("MB") != std::string::npos)
+			win_raw = win_raw.substr(0, win_raw.find("MB"));
+		if (!win_raw.empty()) {
+			float win_mb = std::stof(win_raw);
+			if (win_mb >= 1000.0f) {
+				win_val = clean_float_str(win_mb / 1000.0f);
+				win_unit = "GB";
+			} else {
+				win_val = win_raw;
+				win_unit = "MB";
+			}
+		}
+	}
+	if (win_val == "NA") win_unit = "";
+	win_display = (win_val == "NA") ? "NA" : win_val + " " + win_unit;
+	DataManager::SetValue("tw_winpart_size", win_val);
+	DataManager::SetValue("tw_winpart_unit", win_unit);
+	DataManager::SetValue("tw_winpart_display", win_display);
+	if (win_val != "NA")
+		LOGINFO("WIN Partition Size: %s\n", win_display.c_str());
+
+	// ESP Partition
+	if (Exec_Cmd("blockdev --getsize64 /dev/block/by-name/esp | awk '{printf \"%.0fMB\\n\", $1 / 1000 / 1000}'", esp_raw, true) == 0) {
+		if (esp_raw.find("MB") != std::string::npos)
+			esp_raw = esp_raw.substr(0, esp_raw.find("MB"));
+		if (!esp_raw.empty()) {
+			float esp_mb = std::stof(esp_raw);
+			if (esp_mb >= 1000.0f) {
+				esp_val = clean_float_str(esp_mb / 1000.0f);
+				esp_unit = "GB";
+			} else {
+				esp_val = esp_raw;
+				esp_unit = "MB";
+			}
+		}
+	}
+	if (esp_val == "NA") esp_unit = "";
+	esp_display = (esp_val == "NA") ? "NA" : esp_val + " " + esp_unit;
+	DataManager::SetValue("tw_esppart_size", esp_val);
+	DataManager::SetValue("tw_esppart_unit", esp_unit);
+	DataManager::SetValue("tw_esppart_display", esp_display);
+	if (esp_val != "NA")
+		LOGINFO("ESP Partition Size: %s\n", esp_display.c_str());
+
+	// USERDATA Partition
+	if (Exec_Cmd("blockdev --getsize64 /dev/block/by-name/userdata | awk '{printf \"%.0fMB\\n\", $1 / 1000 / 1000}'", userdata_raw, true) == 0) {
+		if (userdata_raw.find("MB") != std::string::npos)
+			userdata_raw = userdata_raw.substr(0, userdata_raw.find("MB"));
+		if (!userdata_raw.empty()) {
+			float userdata_mb = std::stof(userdata_raw);
+			if (userdata_mb >= 1000.0f) {
+				userdata_val = clean_float_str(userdata_mb / 1000.0f);
+				userdata_unit = "GB";
+			} else {
+				userdata_val = userdata_raw;
+				userdata_unit = "MB";
+			}
+		}
+	}
+	if (userdata_val == "NA") userdata_unit = "";
+	userdata_display = (userdata_val == "NA") ? "NA" : userdata_val + " " + userdata_unit;
+	DataManager::SetValue("tw_userdatapart_size", userdata_val);
+	DataManager::SetValue("tw_userdatapart_unit", userdata_unit);
+	DataManager::SetValue("tw_userdatapart_display", userdata_display);
+	if (userdata_val != "NA")
+		LOGINFO("USERDATA Partition Size: %s\n", userdata_display.c_str());
+}
