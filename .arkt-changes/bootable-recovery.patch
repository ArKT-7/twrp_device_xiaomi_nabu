+void TWFunc::FormatByArKT() 
+{
+    // Check which partitions are selected to format
+    bool format_lin = DataManager::GetIntValue("arkt_format_lin") == 1;
+    bool format_esp = DataManager::GetIntValue("arkt_format_esp") == 1;
+
+    // Exit early if nothing is selected
+    if (!format_lin && !format_esp) {
+        gui_print("Nothing selected to format.\n");
+        return;
+    }
+
+    // Print appropriate start message
+	if (format_lin && format_esp) {
+		gui_print("\nFormatting LINUX and ESP partitions...\n");
+	} else if (format_lin) {
+		gui_print("\nFormatting only LINUX partition...");
+		gui_print(" ");
+	} else if (format_esp) {
+		gui_print("\nFormatting only ESP partition...");
+	}
+
+    // Format LINUX and ESP partitions asynchronously
+    std::thread([format_lin, format_esp] {
+        std::this_thread::sleep_for(std::chrono::milliseconds(300));
+
+        const std::string lin_part = "/dev/block/platform/soc/1d84000.ufshc/by-name/linux";
+        const std::string esp_part = "/dev/block/platform/soc/1d84000.ufshc/by-name/esp";
+
+        // Check if selected partitions actually exist
+        if ((format_lin && !TWFunc::Path_Exists(lin_part)) ||
+            (format_esp && !TWFunc::Path_Exists(esp_part))) {
+            gui_print("Nothing to format. Check your partitions if it has Linux & ESP Partitions.\n");
+            return;
+        }
+
+        Exec_Cmd("sync");
+        if (format_lin)
+            Exec_Cmd("umount -lf " + lin_part + " >/dev/null 2>&1 || true");
+        if (format_esp)
+            Exec_Cmd("umount -lf " + esp_part + " >/dev/null 2>&1 || true");
+
+        std::this_thread::sleep_for(std::chrono::milliseconds(500));
+
+        // Clear first sector to erase old data
+        if (format_lin)
+            Exec_Cmd("dd if=/dev/zero of=" + lin_part + " bs=512 count=1 >/dev/null 2>&1 || true");
+        if (format_esp)
+            Exec_Cmd("dd if=/dev/zero of=" + esp_part + " bs=512 count=1 >/dev/null 2>&1 || true");
+
+        Exec_Cmd("sync");
+
+        std::string esp_out, lin_out;
+        int esp_code = 0, lin_code = 0;
+
+        // Format ESP partition as FAT32
+        if (format_esp) {
+            esp_code = Exec_Cmd("mkfs.fat -F32 -s1 " + esp_part + " -n ESPNABU", esp_out, true);
+            gui_print("\n%s\n", esp_out.c_str());
+        }
+
+        // Format LINUX partition
+        if (format_lin) {
+            lin_code = Exec_Cmd("mkfs.ext4 -F -L linux " + lin_part, lin_out, true);
+            gui_print("%s\n", lin_out.c_str());
+        }
+
+        std::this_thread::sleep_for(std::chrono::milliseconds(500));
+        Exec_Cmd("sync");
+
+        if ((format_lin && lin_code != 0) || (format_esp && esp_code != 0))
+            gui_print("Formatting failed for one or both partitions. Check above.\n");
+        else
+            gui_print("formatted successfully!\n");
+
+        sync();
+    }).detach();
+}
