+// Show UI to ask user for Windows partition size, validate input
+int GUIAction::partitionaskbyarkt(std::string arg __unused)
+{
+    // Prevent partitioning if mass storage enabled
+    if (access("/config/usb_gadget/g1/configs/b.1/mass_storage.0", F_OK) == 0) {
+        gui_print("\nMass storage is already enabled!\n");
+        gui_changeOverlay("msc_enabled_warn");
+        return 1;
+    }
+
+    // Show partition ask overlay if not confirmed
+    if (arg != "pass") {
+        gui_changeOverlay("partition_ask");
+        return 0;
+    }
+
+    TWFunc::PartitionSizesByArKT();
+
+    // Constants for reserved partitions for userdata and systems in MB
+    const int RESERVED_END   = 7000;
+    const int RESERVED_START = 11222;
+
+    std::string value;
+    DataManager::GetValue(ARKT_PART_SIZE, value);
+
+    std::string total_mb_str;
+    DataManager::GetValue("arkt_blockpart_size", total_mb_str);
+
+    if (total_mb_str.empty()) {
+        gui_changeOverlay("slideout");
+        gui_print("Error: Unable to retrieve usable block size!\n");
+        return 1;
+    }
+
+    long long total_usable_mb = std::stoll(total_mb_str);
+    double win_max = total_usable_mb / 1000.0;
+    double win_gb = std::stod(value);
+
+    // Validate partition size input is within allowed range
+    if (win_gb < 30.0 || win_gb > win_max) {
+        gui_changeOverlay("partition_warn");
+        return 1;
+    }
+
+    // Align Windows partition end to 1MB boundary
+    long long win_end_mb = static_cast<long long>(win_gb * 1000.0);
+    win_end_mb = ((win_end_mb + 1023) / 1024) * 1024;
+    win_gb = static_cast<double>(win_end_mb) / 1000.0;
+
+    double userdata_mb = static_cast<double>(total_usable_mb) - win_end_mb + RESERVED_END;
+    double userdata_gb = userdata_mb / 1000.0;
+
+    LOGINFO("Windows Partition: %.2f GB\n", win_gb);
+    LOGINFO("Android Partition: %.2f GB\n", userdata_gb);
+
+    char win_str[16], user_str[16];
+    snprintf(win_str, sizeof(win_str), "%.2f", win_gb);
+    snprintf(user_str, sizeof(user_str), "%.2f", userdata_gb);
+
+    // Store partition sizes for later steps
+    DataManager::SetValue("win_part_size", std::string(win_str));
+    DataManager::SetValue("userdata_part_size", std::string(user_str));
+    DataManager::SetValue("win_end_size", static_cast<int>(win_end_mb + RESERVED_START));
+
+    gui_changeOverlay("partition_confirm");
+    return 0;
+}
+
+// Perform partitioning of device with Windows, Esp and Android partitions
+int GUIAction::partitionByArKT(std::string arg __unused)
+{
+    gui_changeOverlay("slideout");
+    gui_print("\nProceeding with Windows partitioning!\n");
+    sync();
+
+    // Run partitioning asynchronously
+    std::thread([] {
+        std::this_thread::sleep_for(std::chrono::milliseconds(300));
+        TWFunc::CommonByArKT();
+        std::this_thread::sleep_for(std::chrono::milliseconds(500));
+
+        unsigned long long winend;
+        DataManager::GetValue("win_end_size", winend);
+
+        gui_print("Removing partitions...\n");
+        TWFunc::Exec_Cmd("for i in $(seq 31 40); do parted -s /dev/block/sda rm $i 2>/dev/null || true; done");
+
+        gui_print("Resizing partition table...\n");
+        TWFunc::Exec_Cmd("sgdisk --resize-table 64 /dev/block/sda");
+
+        gui_print("Creating partitions...\n");
+        TWFunc::Exec_Cmd("parted -s /dev/block/sda mkpart esp fat32 10872MB 11222MB");
+
+        std::string win_end_str = std::to_string(winend) + "MB";
+        TWFunc::Exec_Cmd("parted -s /dev/block/sda mkpart win ntfs 11222MB " + win_end_str);
+        TWFunc::Exec_Cmd("parted -s /dev/block/sda mkpart userdata ext4 " + win_end_str + " 100%");
+        TWFunc::Exec_Cmd("parted -s /dev/block/sda set 31 esp on");
+
+        std::this_thread::sleep_for(std::chrono::milliseconds(500));
+        TWFunc::Exec_Cmd("sync");
+
+        gui_print("Formatting userdata(Android)...\n");
+        TWFunc::Exec_Cmd("make_f2fs -f -g android /dev/block/sda33");
+
+        gui_print("Formatting metadata...\n");
+        TWFunc::Exec_Cmd("mke2fs -t ext4 -F /dev/block/sda19");
+        sync();
+
+        gui_print("Formatting ESP Partition...\n");
+        TWFunc::Exec_Cmd("mkfs.fat -F32 -s1 /dev/block/sda31 -n ESPNABU");
+
+        gui_print("Formatting Windows Partition...\n");
+        TWFunc::Exec_Cmd("mkfs.ntfs -f /dev/block/sda32 -L WINNABU");
+        sync();
+
+        // Fix GPT for 24h2 windows edl brick
+        for (char suffix = 'a'; suffix <= 'f'; ++suffix) {
+            std::string device = "/dev/block/sd";
+            device += suffix;
+
+            gui_print("Fixing GPT on %s...\n", device.c_str());
+            TWFunc::Exec_Cmd(
+                "echo -e \"x\\nj\\n\\nk\\n\\nw\\nY\\n\" | gdisk " + device
+            );
+        }
+
+        TWFunc::partedprintByArKT();
+        std::this_thread::sleep_for(std::chrono::milliseconds(700));
+        TWFunc::PartitionSizesByArKT();
+    }).detach();
+
+    sync();
+    return 0;
+}
