+// Restore stock partitions after confirmation ("pass" arg)
+int GUIAction::restorebyarkt(std::string arg __unused)
+{
+    // Prevent restore if mass storage enabled
+    if (access("/config/usb_gadget/g1/configs/b.1/mass_storage.0", F_OK) == 0) {
+        gui_print("\nMass storage is already enabled!\n");
+        gui_changeOverlay("msc_enabled_warn");
+        return 1;
+    }
+
+    // Show confirmation overlay if not confirmed yet
+    if (arg != "pass") {
+        gui_changeOverlay("restore_warn");
+        return 0;
+    }
+
+    gui_changeOverlay("slideout");
+    sync();
+
+    // Run restore steps asynchronously to avoid blocking UI
+    std::thread([] {
+        std::this_thread::sleep_for(std::chrono::milliseconds(300));
+
+        TWFunc::CommonByArKT();
+        gui_print("Restoring partitions to stock...\n\n");
+
+        gui_print("Making partitions stock...\n");
+        TWFunc::Exec_Cmd("sgdisk --clear --load-backup=/system/bin/gpt0 /dev/block/sda");
+
+        gui_print("resizing userdata(Android) partition...\n");
+        TWFunc::Exec_Cmd("parted -s /dev/block/sda resizepart 31 100%");
+
+        gui_print("Formatting userdata...\n");
+        TWFunc::Exec_Cmd("make_f2fs -f -g android /dev/block/sda31");
+
+        gui_print("Formatting metadata...\n");
+        TWFunc::Exec_Cmd("mke2fs -t ext4 -F /dev/block/sda19");
+
+        TWFunc::partedprintByArKT();
+        std::this_thread::sleep_for(std::chrono::milliseconds(700));
+        TWFunc::PartitionSizesByArKT();
+    }).detach();
+
+    sync();
+    return 0;
+}
