int GUIAction::reload(std::string arg __unused)
{
	PageManager::RequestReload();
	// The actual reload is handled in pages.cpp in PageManager::RunReload()
	// The reload will occur on the next Update or Render call and will
	// be performed in the rendoer thread instead of the action thread
	// to prevent crashing which could occur when we start deleting
	// GUI resources in the action thread while we attempt to render
	// with those same resources in another thread.
	TWFunc::PartitionSizesByArKT(); // this i added
	return 0;
}

int GUIAction::restoredefaultsettings(std::string arg __unused)
{
	operation_start("Restore Defaults");
	if (simulate) // Simulated so that people don't accidently wipe out the "simulation is on" setting
		gui_msg("simulating=Simulating actions...");
	else {
		DataManager::ResetDefaults();
		PartitionManager.Update_System_Details();
		PartitionManager.Mount_Current_Storage(true);
	}
	operation_end(0);
	TWFunc::PartitionSizesByArKT();  // this i added
	return 0;
}

// Functions By ArKT, telegram - @ArKT_7, Github - https://github.com/ArKT-7

// Enable Mass Storage mode over USB (MSC)
int GUIAction::mscbyarkt(std::string arg)
{
    // If called with "pass", and MSC already enabled, just update UI
    if (arg == "pass") {
        if (access("/config/usb_gadget/g1/configs/b.1/mass_storage.0", F_OK) == 0) {
            gui_changeOverlay("slideout"); // Show overlay immediately
            gui_print("re-enabling MSC again\n");
        }
    }
    // If MSC already enabled, notify and show appropriate overlay
    else if (access("/config/usb_gadget/g1/configs/b.1/mass_storage.0", F_OK) == 0) {
        gui_print("\nMass storage is already enabled!\n");
        gui_changeOverlay("msc_enabled");
        return 1;
    }

    gui_changeOverlay("slideout");
    TWFunc::Exec_Cmd("sync");

    // Run enabling MSC asynchronously to avoid blocking UI
    std::thread([] {
        std::this_thread::sleep_for(std::chrono::milliseconds(300));

        TWFunc::CommonByArKT();
        gui_print("Enabling Mass Storage...\n");

        // Set USB gadget parameters for MSC mode and link mass_storage function
        std::string bash_script = R"(
            setenforce 0;
            echo 0x2717 > /config/usb_gadget/g1/idVendor;
            echo 0x9039 > /config/usb_gadget/g1/idProduct;
            echo 0xEF > /config/usb_gadget/g1/bDeviceClass;
            echo 0x02 > /config/usb_gadget/g1/bDeviceSubClass;
            echo 0x01 > /config/usb_gadget/g1/bDeviceProtocol;
            ln -s /config/usb_gadget/g1/functions/mass_storage.0 /config/usb_gadget/g1/configs/b.1/ 2>/dev/null;
            echo /dev/block/sda > /config/usb_gadget/g1/configs/b.1/mass_storage.0/lun.0/file;
            echo 0 > /config/usb_gadget/g1/configs/b.1/mass_storage.0/lun.0/removable;
            echo '' > /config/usb_gadget/g1/UDC 2>/dev/null;
            echo a600000.dwc3 > /config/usb_gadget/g1/UDC 2>/dev/null;
        )";

        TWFunc::Exec_Cmd(("sh -c '" + bash_script + "'").c_str());
        gui_print("\nDone!\n");
    }).detach();

    sync();
    return 0;
}

// Format Windows partition (calls helper)
int GUIAction::formatwinbyarkt(std::string arg __unused)
{
    gui_changeOverlay("slideout");
    sync();
    TWFunc::FormatWinByArKT();
    return 0;
}

// Print partition info
int GUIAction::printpartitionsbyarkt(std::string arg __unused)
{
    gui_changeOverlay("slideout");
    TWFunc::partedprintByArKT();
    return 0;
}

// Show rotation warning UI, perform rotation logic
int GUIAction::rotationbyarkt(std::string arg __unused)
{
	gui_changeOverlay("rotation_warn");
	// Run restore steps asynchronously to avoid blocking UI
    std::thread([] {
		sync();
        std::this_thread::sleep_for(std::chrono::milliseconds(300));
    	TWFunc::RotationByArkt();
    }).detach();

    sync();
    return 0;
}

// Reboot device with different options based on arg
int GUIAction::rebootbyarkt(std::string arg)
{
    if (arg == "r") {
        TWFunc::Exec_Cmd("reboot >/dev/null 2>&1 || true");
    } else if (arg == "rtbl") {
        TWFunc::Exec_Cmd("reboot bootloader >/dev/null 2>&1 || true");
    } else if (arg == "rtr") {
        TWFunc::Exec_Cmd("reboot recovery >/dev/null 2>&1 || true");
    } else if (arg == "off") {
        TWFunc::Exec_Cmd("reboot poweroff >/dev/null 2>&1 || true");
    }
    return 0;
}

// Restore stock partitions after confirmation ("pass" arg)
int GUIAction::restorebyarkt(std::string arg __unused)
{
    // Prevent restore if mass storage enabled
    if (access("/config/usb_gadget/g1/configs/b.1/mass_storage.0", F_OK) == 0) {
        gui_print("\nMass storage is already enabled!\n");
        gui_changeOverlay("msc_enabled_warn");
        return 1;
    }

    // Show confirmation overlay if not confirmed yet
    if (arg != "pass") {
        gui_changeOverlay("restore_warn");
        return 0;
    }

    gui_changeOverlay("slideout");
    sync();

    // Run restore steps asynchronously to avoid blocking UI
    std::thread([] {
        std::this_thread::sleep_for(std::chrono::milliseconds(300));

        TWFunc::CommonByArKT();
        gui_print("Restoring partitions to stock...\n\n");

        gui_print("Removing partitions...\n");
        TWFunc::Exec_Cmd("for i in $(seq 31 40); do parted -s /dev/block/sda rm $i 2>/dev/null || true; done");

        gui_print("Creating userdata(Android) partition...\n");
        TWFunc::Exec_Cmd("parted -s /dev/block/sda mkpart userdata ext4 10872MB 100%");

        gui_print("Resizing partition table...\n");
        TWFunc::Exec_Cmd("sgdisk --resize-table 32 /dev/block/sda");
        TWFunc::Exec_Cmd("sync");

        gui_print("Formatting userdata...\n");
        TWFunc::Exec_Cmd("make_f2fs -f -g android /dev/block/sda31");

        gui_print("Formatting metadata...\n");
        TWFunc::Exec_Cmd("mke2fs -t ext4 -F /dev/block/sda19");

        TWFunc::partedprintByArKT();
        std::this_thread::sleep_for(std::chrono::milliseconds(700));
        TWFunc::PartitionSizesByArKT();
    }).detach();

    sync();
    return 0;
}

// Show UI to ask user for Windows partition size, validate input
int GUIAction::partitionaskbyarkt(std::string arg __unused)
{
    // Prevent partitioning if mass storage enabled
    if (access("/config/usb_gadget/g1/configs/b.1/mass_storage.0", F_OK) == 0) {
        gui_print("\nMass storage is already enabled!\n");
        gui_changeOverlay("msc_enabled_warn");
        return 1;
    }

    // Show partition ask overlay if not confirmed
    if (arg != "pass") {
        gui_changeOverlay("partition_ask");
        return 0;
    }

    TWFunc::PartitionSizesByArKT();

    // Constants for reserved partitions for userdata and systems in MB
    const int RESERVED_END   = 7000;
    const int RESERVED_START = 11222;

    std::string value;
    DataManager::GetValue(ARKT_PART_SIZE, value);

    std::string total_mb_str;
    DataManager::GetValue("arkt_blockpart_size", total_mb_str);

    if (total_mb_str.empty()) {
        gui_changeOverlay("slideout");
        gui_print("Error: Unable to retrieve usable block size!\n");
        return 1;
    }

    long long total_usable_mb = std::stoll(total_mb_str);
    double win_max = total_usable_mb / 1000.0;
    double win_gb = std::stod(value);

    // Validate partition size input is within allowed range
    if (win_gb < 30.0 || win_gb > win_max) {
        gui_changeOverlay("partition_warn");
        return 1;
    }

    // Align Windows partition end to 1MB boundary
    long long win_end_mb = static_cast<long long>(win_gb * 1000.0);
    win_end_mb = ((win_end_mb + 1023) / 1024) * 1024;
    win_gb = static_cast<double>(win_end_mb) / 1000.0;

    double userdata_mb = static_cast<double>(total_usable_mb) - win_end_mb + RESERVED_END;
    double userdata_gb = userdata_mb / 1000.0;

    LOGINFO("Windows Partition: %.2f GB\n", win_gb);
    LOGINFO("Android Partition: %.2f GB\n", userdata_gb);

    char win_str[16], user_str[16];
    snprintf(win_str, sizeof(win_str), "%.2f", win_gb);
    snprintf(user_str, sizeof(user_str), "%.2f", userdata_gb);

    // Store partition sizes for later steps
    DataManager::SetValue("win_part_size", std::string(win_str));
    DataManager::SetValue("userdata_part_size", std::string(user_str));
    DataManager::SetValue("win_end_size", static_cast<int>(win_end_mb + RESERVED_START));

    gui_changeOverlay("partition_confirm");
    return 0;
}

// Perform partitioning of device with Windows, Esp and Android partitions
int GUIAction::partitionByArKT(std::string arg __unused)
{
    gui_changeOverlay("slideout");
    gui_print("\nProceeding with Windows partitioning!\n");
    sync();

    // Run partitioning asynchronously
    std::thread([] {
        std::this_thread::sleep_for(std::chrono::milliseconds(300));
        TWFunc::CommonByArKT();
        std::this_thread::sleep_for(std::chrono::milliseconds(500));

        unsigned long long winend;
        DataManager::GetValue("win_end_size", winend);

        gui_print("Removing partitions...\n");
        TWFunc::Exec_Cmd("for i in $(seq 31 40); do parted -s /dev/block/sda rm $i 2>/dev/null || true; done");

        gui_print("Resizing partition table...\n");
        TWFunc::Exec_Cmd("sgdisk --resize-table 64 /dev/block/sda");

        gui_print("Creating partitions...\n");
        TWFunc::Exec_Cmd("parted -s /dev/block/sda mkpart esp fat32 10872MB 11222MB");

        std::string win_end_str = std::to_string(winend) + "MB";
        TWFunc::Exec_Cmd("parted -s /dev/block/sda mkpart win ntfs 11222MB " + win_end_str);
        TWFunc::Exec_Cmd("parted -s /dev/block/sda mkpart userdata ext4 " + win_end_str + " 100%");
        TWFunc::Exec_Cmd("parted -s /dev/block/sda set 31 esp on");

        std::this_thread::sleep_for(std::chrono::milliseconds(500));
        TWFunc::Exec_Cmd("sync");

        gui_print("Formatting userdata(Android)...\n");
        TWFunc::Exec_Cmd("make_f2fs -f -g android /dev/block/sda33");

        gui_print("Formatting metadata...\n");
        TWFunc::Exec_Cmd("mke2fs -t ext4 -F /dev/block/sda19");
        sync();

        gui_print("Formatting ESP Partition...\n");
        TWFunc::Exec_Cmd("mkfs.fat -F32 -s1 /dev/block/sda31 -n ESPNABU");

        gui_print("Formatting Windows Partition...\n");
        TWFunc::Exec_Cmd("mkfs.ntfs -f /dev/block/sda32 -L WINNABU");
        sync();

        // Fix GPT for 24h2 windows edl brick
        for (char suffix = 'a'; suffix <= 'f'; ++suffix) {
            std::string device = "/dev/block/sd";
            device += suffix;

            gui_print("Fixing GPT on %s...\n", device.c_str());
            TWFunc::Exec_Cmd(
                "echo -e \"x\\nj\\n\\nk\\n\\nw\\nY\\n\" | gdisk " + device
            );
        }

        TWFunc::partedprintByArKT();
        std::this_thread::sleep_for(std::chrono::milliseconds(700));
        TWFunc::PartitionSizesByArKT();
    }).detach();

    sync();
    return 0;
}


