// Functions By ArKT , telegram - @ArKT_7, Github - https://github.com/ArKT-7

void TWFunc::PartitionSizesByArKT() 
{
    std::string block_raw, win_raw, esp_raw, userdata_raw;
    std::string block_val = "NA", block_unit = "MB", block_display = "NA";
    std::string win_val = "NA", win_unit = "MB", win_display = "NA";
    std::string esp_val = "NA", esp_unit = "MB", esp_display = "NA";
    std::string userdata_val = "NA", userdata_unit = "MB", userdata_display = "NA";

    const int RESERVED_START = 11222;
    const int RESERVED_END   = 7000;

    // Helper lambda to clean float string (remove trailing zeros)
    auto clean_float_str = [](float value) -> std::string {
        std::ostringstream oss;
        oss.precision(2);
        oss << std::fixed << value;
        std::string out = oss.str();
        while (out.back() == '0') out.pop_back();
        if (out.back() == '.') out.pop_back();
        return out;
    };

    // Get block total size (adjusted for reserved space)
    if (Exec_Cmd("blockdev --getsize64 /dev/block/sda | awk '{print int($1 / 1000000)}'", block_raw, true) == 0) {
        block_raw.erase(std::remove(block_raw.begin(), block_raw.end(), '\n'), block_raw.end());

        if (!block_raw.empty()) {
            long long max = std::stoll(block_raw);
            long long usable_mb = max - RESERVED_START - RESERVED_END;
            long long winmax = usable_mb / 1000;

            block_val = std::to_string(usable_mb);
            block_display = std::to_string(winmax);
        }
    }

    DataManager::SetValue("arkt_blockpart_size", block_val);
    DataManager::SetValue("arkt_blockpart_display", block_display);

    if (block_val != "NA")
        LOGINFO("BLOCK Partition Aligned Size: %s MB, Display: %s GB\n", block_val.c_str(), block_display.c_str());

    // Lambda to parse partition size and set related values
    auto ParsePartitionSize = [&](const std::string& part_name, std::string& out_raw,
                                  std::string& out_val, std::string& out_unit, std::string& out_display,
                                  const std::string& arkt_key) {
        std::string cmd = "parted /dev/block/sda unit MB print | awk -v name=\"" + part_name + "\" "
                  "'$0 ~ /^[ 0-9]+/ { name_col=0; for(i=1;i<=NF;i++) if($i==name) name_col=i; "
                  "if(name_col > 0 && $(name_col)==name) { gsub(\"MB\", \"\", $4); print $4 } }'";
        
        if (Exec_Cmd(cmd, out_raw, true) == 0) {
            out_raw.erase(std::remove(out_raw.begin(), out_raw.end(), '\n'), out_raw.end());
            out_raw.erase(std::remove(out_raw.begin(), out_raw.end(), ' '), out_raw.end());

            if (!out_raw.empty()) {
                float mb = std::stof(out_raw);
                if (mb >= 1000.0f) {
                    out_val = clean_float_str(mb / 1000.0f);
                    out_unit = "GB";
                } else {
                    out_val = out_raw;
                    out_unit = "MB";
                }
            }
        }

        if (out_val == "NA") out_unit = "";

        out_display = (out_val == "NA") ? "NA" : out_val + " " + out_unit;

        DataManager::SetValue("arkt_" + arkt_key + "part_size", out_val);
        DataManager::SetValue("arkt_" + arkt_key + "part_unit", out_unit);
        DataManager::SetValue("arkt_" + arkt_key + "part_display", out_display);

        if (out_val != "NA")
            LOGINFO("%s Partition Size: %s\n", arkt_key.c_str(), out_display.c_str());
    };

    // Parse each partition safely
    ParsePartitionSize("win", win_raw, win_val, win_unit, win_display, "win");
    ParsePartitionSize("esp", esp_raw, esp_val, esp_unit, esp_display, "esp");
    ParsePartitionSize("userdata", userdata_raw, userdata_val, userdata_unit, userdata_display, "userdata");
}


void TWFunc::RotationByArkt() 
{
    LOGINFO("TWRP ROTATION BY ARKT...\n");

    // Prepare environment
    chdir("/");
    umask(022);

    LOGINFO("Backing up current twres...\n");

    // Backup current twres layout files
    Exec_Cmd("mkdir -p /twres/twres-arkt/backup");
    Exec_Cmd("mv /twres/ui.xml /twres/twres-arkt/backup/ui.xml");
    Exec_Cmd("mv /twres/splash.xml /twres/twres-arkt/backup/splash.xml");
    Exec_Cmd("mv /twres/images /twres/twres-arkt/backup/images");

    Exec_Cmd("[ -f /twres/portrait.xml ] && mv /twres/portrait.xml /twres/twres-arkt/backup/portrait.xml");
    Exec_Cmd("[ -f /twres/landscape.xml ] && mv /twres/landscape.xml /twres/twres-arkt/backup/landscape.xml");

    LOGINFO("Swapping in new layout...\n");

    // Replace with new layout files
    Exec_Cmd("mv /twres/twres-arkt/ui.xml /twres/");
    Exec_Cmd("mv /twres/twres-arkt/splash.xml /twres/");
    Exec_Cmd("mv /twres/twres-arkt/images /twres/");

    Exec_Cmd("[ -f /twres/twres-arkt/portrait.xml ] && mv /twres/twres-arkt/portrait.xml /twres/");
    Exec_Cmd("[ -f /twres/twres-arkt/landscape.xml ] && mv /twres/twres-arkt/landscape.xml /twres/");

    LOGINFO("Moving previous layout into /twres-arkt...\n");

    // Restore backup files to twres-arkt folder for future swaps
    Exec_Cmd("mv /twres/twres-arkt/backup/ui.xml /twres/twres-arkt/ui.xml");
    Exec_Cmd("mv /twres/twres-arkt/backup/splash.xml /twres/twres-arkt/splash.xml");
    Exec_Cmd("mv /twres/twres-arkt/backup/images /twres/twres-arkt/images");

    // Move specific images back to images folder
    Exec_Cmd("mv /twres/twres-arkt/images/splashteamwin.png /twres/images/");
    Exec_Cmd("mv /twres/twres-arkt/images/enter_terminal.png /twres/images/");
    Exec_Cmd("mv /twres/twres-arkt/images/shift_terminal.png /twres/images/");
    Exec_Cmd("mv /twres/twres-arkt/images/win.png /twres/images/");
    Exec_Cmd("mv /twres/twres-arkt/images/main_button_half_width_low.png /twres/images/");
    Exec_Cmd("mv /twres/twres-arkt/images/shift_terminal_fill.png /twres/images/");
    Exec_Cmd("mv /twres/twres-arkt/images/splashlogo.png /twres/images/");
    Exec_Cmd("mv /twres/twres-arkt/images/backspace_terminal.png /twres/images/");
    Exec_Cmd("mv /twres/twres-arkt/images/main_button_half_width.png /twres/images/");
    Exec_Cmd("mv /twres/twres-arkt/images/space_terminal.png /twres/images/");
    Exec_Cmd("mv /twres/twres-arkt/images/unlock_icon.png /twres/images/");
    Exec_Cmd("mv /twres/twres-arkt/images/cursor.png /twres/images/");

    Exec_Cmd("[ -f /twres/twres-arkt/backup/portrait.xml ] && mv /twres/twres-arkt/backup/portrait.xml /twres/twres-arkt/portrait.xml");
    Exec_Cmd("[ -f /twres/twres-arkt/backup/landscape.xml ] && mv /twres/twres-arkt/backup/landscape.xml /twres/twres-arkt/landscape.xml");

    // Swap libraries for rotation
    Exec_Cmd("[ -f /system/lib64/libminuitwrp.so ] && mv /system/lib64/libminuitwrp.so /system/lib64/libminuitwrp-arkt-1.so");
    Exec_Cmd("[ -f /system/lib64/libminuitwrp-arkt.so ] && mv /system/lib64/libminuitwrp-arkt.so /system/lib64/libminuitwrp.so");
    Exec_Cmd("[ -f /system/lib64/libminuitwrp-arkt-1.so ] && mv /system/lib64/libminuitwrp-arkt-1.so /system/lib64/libminuitwrp-arkt.so");

    // Swap ramdisk files for rotation
    Exec_Cmd("[ -f /ramdisk-files.txt ] && mv /ramdisk-files.txt /ramdisk-files-arkt-1.txt");
    Exec_Cmd("[ -f /ramdisk-files-arkt.txt ] && mv /ramdisk-files-arkt.txt /ramdisk-files.txt");
    Exec_Cmd("[ -f /ramdisk-files-arkt-1.txt ] && mv /ramdisk-files-arkt-1.txt /ramdisk-files-arkt.txt");

    LOGINFO("Unmounting and reinitializing...\n");
    sync();
    DataManager::Flush();

    // Unmount partitions forcefully
    Exec_Cmd("umount -lf /dev/block/platform/soc/1d84000.ufshc/by-name/win >/dev/null 2>&1 || true");
    Exec_Cmd("umount -lf /dev/block/platform/soc/1d84000.ufshc/by-name/esp >/dev/null 2>&1 || true");

    Exec_Cmd("sync");

    // Fork a child process to kill twrp with SIGUSR1 to rotate UI
    pid_t pid = fork();
    if (pid == 0) {
        ::sleep(1);
        LOGINFO("KILLING TWRP FOR ROTATION...\n");
        execlp("killall", "killall", "-SIGUSR1", "recovery", (char*)nullptr);
        _exit(0); // child exit
    }

    LOGINFO("TWRP ROTATION DONE BY ARKT ...\n");
}


void TWFunc::CommonByArKT() 
{
    // Check if MTP mode is active, then reset USB to ADB mode
    int mtpActive = system("getprop sys.usb.config | grep -q 'mtp'");
    if (mtpActive == 0) {
        gui_print("\nMTP mode detected. Resetting USB to ADB...\n");
        PartitionManager.Disable_MTP();
        android::base::SetProperty("sys.usb.config", "none");
        android::base::SetProperty("sys.usb.config", "adb");
        Exec_Cmd("rm -f /config/usb_gadget/g1/configs/b.1/f* || true");
        ::sleep(2);
    }

    gui_print("\nUnmounting all related partitions...\n");

    // Unmount common mount points and partitions
    Exec_Cmd("for i in sdcard data; do umount -lf /$i 2>/dev/null || true; done");
    Exec_Cmd("dmsetup remove -f userdata 2>/dev/null || true");
    Exec_Cmd("for i in esp win firmware mnt userdata metadata misc vendor; do umount -lf /dev/block/platform/soc/1d84000.ufshc/by-name/$i > /dev/null 2>&1 || true; done");
}


void TWFunc::partedprintByArKT() 
{
    gui_print("\nFetching partition list...\n\n");

    // Run parted asynchronously to get and print partition info
    std::thread([] {
        std::this_thread::sleep_for(std::chrono::milliseconds(100));
        std::string parted_output;
        int code = Exec_Cmd("parted /dev/block/sda p free", parted_output, true);

        if (code != 0 || parted_output.empty()) {
            gui_print("Failed to get partition list.\n");
            gui_print("%s\n", parted_output.c_str());
            return;
        }

        std::istringstream stream(parted_output);
        std::string line;

        while (std::getline(stream, line)) {
            gui_print("%s\n", line.c_str());
            std::this_thread::sleep_for(std::chrono::milliseconds(5));
        }

        gui_print("\nDone!\n");
    }).detach();

    gui_print("\n");
}


void TWFunc::FormatWinByArKT() 
{
    gui_print("\nFormatting WIN and ESP partitions...\n");

    // Format WIN and ESP partitions asynchronously
    std::thread([] {
        std::this_thread::sleep_for(std::chrono::milliseconds(300));

        std::string win_part = "/dev/block/platform/soc/1d84000.ufshc/by-name/win";
        std::string esp_part = "/dev/block/platform/soc/1d84000.ufshc/by-name/esp";

        if (!TWFunc::Path_Exists(win_part) || !TWFunc::Path_Exists(esp_part)) {
            gui_print("Nothing to format. Check your partitions if it has Windows & ESP Partitions.\n");
            return;
        }

        Exec_Cmd("sync");
        Exec_Cmd("umount -lf " + win_part + " >/dev/null 2>&1 || true");
        Exec_Cmd("umount -lf " + esp_part + " >/dev/null 2>&1 || true");

        std::this_thread::sleep_for(std::chrono::milliseconds(500));

        // Clear first sector to erase old data
        Exec_Cmd("dd if=/dev/zero of=" + win_part + " bs=512 count=1 >/dev/null 2>&1 || true");
        Exec_Cmd("dd if=/dev/zero of=" + esp_part + " bs=512 count=1 >/dev/null 2>&1 || true");
        Exec_Cmd("sync");

        // Attempt quick fix on NTFS partition
        Exec_Cmd("ntfsfix " + win_part + " >/dev/null 2>&1 || true");

        // Format ESP partition as FAT32
        std::string esp_out;
        int esp_code = Exec_Cmd("mkfs.fat -F32 -s1 " + esp_part + " -n ESPNABU", esp_out, true);
        gui_print("\n%s", esp_out.c_str());

        std::this_thread::sleep_for(std::chrono::milliseconds(500));

        // Format WIN partition as NTFS
        std::string win_out;
        int win_code = Exec_Cmd("mkfs.ntfs -f " + win_part + " -L WINNABU", win_out, true);
        gui_print("%s\n", win_out.c_str());

        std::this_thread::sleep_for(std::chrono::milliseconds(500));
        Exec_Cmd("sync");

        if (esp_code == 0 && win_code == 0)
            gui_print("Both WIN and ESP formatted successfully!\n");
        else
            gui_print("Formatting failed for one or both partitions. Check above.\n");

        sync();
    }).detach();
}


